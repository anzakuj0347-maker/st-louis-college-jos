<article class="student-report-card" data-subject-count="<%= subjectResults.length %>">
  <header class="report-card-top">
    <img src="/images/logo.jpg" alt="St. Louis College Jos Logo" class="report-card-logo">
    <div class="report-card-school">
      <h1 class="report-card-school-name">St. Louis College Jos</h1>
      <p class="report-card-school-address">Jos, Plateau State, Nigeria</p>
      <p class="report-card-school-email">info@stlouisvillejos.sch.ng</p>
    </div>
  </header>

  <div class="report-card-title-bar">
    <%= term %> · <%= session %> Report Card
  </div>

  <div class="report-card-student-row">
    <div class="report-card-student-item">
      <span class="report-card-student-label">Student Name:</span>
      <strong><%= student.firstName %><% if (student.middleName) { %> <%= student.middleName %><% } %> <%= student.lastName %></strong>
    </div>
    <div class="report-card-student-item">
      <span class="report-card-student-label">Arm:</span>
      <strong><%= classLevel %> — <%= student.arm || '—' %></strong>
    </div>
    <div class="report-card-student-item">
      <span class="report-card-student-label">Admn No.:</span>
      <strong><%= student.studentId %></strong>
    </div>
  </div>

  <div class="report-card-body">
    <div class="report-card-main report-card-main--full">
      <div class="admin-table-wrap print-table-wrap">
        <table class="print-data-table print-result-table report-card-table">
          <colgroup>
            <col class="report-card-col-subject">
            <col class="report-card-col-score" span="6">
            <col class="report-card-col-metric" span="3">
            <col class="report-card-col-remark">
            <col class="report-card-col-sign">
          </colgroup>
          <thead>
            <tr class="report-card-table-head-top">
              <th colspan="12" class="report-card-term-head"><%= term %> — Scholastic Areas</th>
            </tr>
            <tr class="report-card-table-head-sub">
              <th>Subject</th>
              <th><span class="report-card-th-full">1st Assignment</span><span class="report-card-th-fit">1st Asgn</span><br><span class="report-card-max">(10)</span></th>
              <th><span class="report-card-th-full">2nd Assignment</span><span class="report-card-th-fit">2nd Asgn</span><br><span class="report-card-max">(10)</span></th>
              <th><span class="report-card-th-full">1st Test</span><span class="report-card-th-fit">1st Test</span><br><span class="report-card-max">(20)</span></th>
              <th><span class="report-card-th-full">2nd Test</span><span class="report-card-th-fit">2nd Test</span><br><span class="report-card-max">(20)</span></th>
              <th>Exam<br><span class="report-card-max">(40)</span></th>
              <th>Total<br><span class="report-card-max">(100)</span></th>
              <th><span class="report-card-th-full">Average</span><span class="report-card-th-fit">Avg</span></th>
              <th class="report-card-col-position"><span class="report-card-th-full">Position</span><span class="report-card-th-fit">Pos</span></th>
              <th>Grade</th>
              <th class="report-card-col-remark">Remark</th>
              <th class="report-card-col-sign">Sign</th>
            </tr>
          </thead>
          <tbody>
            <% if (subjectResults.length) { %>
              <% subjectResults.forEach(function(row) { %>
                <tr>
                  <td class="report-card-subject"><%= row.subject %></td>
                  <td class="report-card-score-cell"><%= row.firstAssignment !== '' ? row.firstAssignment : '—' %></td>
                  <td class="report-card-score-cell"><%= row.secondAssignment !== '' ? row.secondAssignment : '—' %></td>
                  <td class="report-card-score-cell"><%= row.firstTest !== '' ? row.firstTest : '—' %></td>
                  <td class="report-card-score-cell"><%= row.secondTest !== '' ? row.secondTest : '—' %></td>
                  <td class="report-card-score-cell"><%= row.exam !== '' ? row.exam : '—' %></td>
                  <td class="report-card-score-cell"><%= row.total || '—' %></td>
                  <td class="report-card-score-cell"><%= row.average !== '' ? row.average : '—' %></td>
                  <td class="report-card-score-cell report-card-col-position"><%= row.position || '—' %></td>
                  <td class="report-card-score-cell"><%= row.grade || '—' %></td>
                  <td class="report-card-remark report-card-col-remark"><%= row.remark || '—' %></td>
                  <td class="report-card-score-cell report-card-col-sign"><%= row.sign || '—' %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="12" class="print-empty">No results recorded for this term and session.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <section class="report-card-summary-panel">
    <div class="report-card-summary-top">
      <div class="report-card-summary-meta">
        <span class="report-card-summary-title">Result Summary</span>
        <span class="report-card-summary-stat"><span class="report-card-summary-label">Subjects</span> <strong><%= summary.subjectsOffered %></strong></span>
        <span class="report-card-summary-stat"><span class="report-card-summary-label">Credits</span> <strong><%= summary.numberOfCredits %></strong></span>
        <span class="report-card-summary-stat"><span class="report-card-summary-label">Class Avg</span> <strong><%= summary.classAverage || '—' %></strong></span>
      </div>
      <% if (typeof showQr === 'undefined' || showQr) { %>
        <div class="report-card-summary-qr">
          <img
            src="<%- typeof qrImageUrl !== 'undefined' && qrImageUrl ? qrImageUrl : '' %>"
            class="print-result-qr-code report-card-summary-qr-code"
            alt="Scan to open verified student result"
            width="52"
            height="52"
            loading="eager"
          >
        </div>
      <% } %>
    </div>

    <div class="report-card-principal-box">
      <h3 class="report-card-principal-title">Principal's Comment</h3>
      <p class="report-card-principal-text"><%= summary.principalComment %></p>
    </div>
  </section>

  <footer class="report-card-footer">
    <div class="report-card-signature">
      <div class="report-card-signature-line"></div>
      <p>Signature of Class Teacher</p>
    </div>

    <div class="report-card-signature">
      <div class="report-card-signature-line"></div>
      <p>Signature of Principal</p>
    </div>
  </footer>
</article>

<% if (typeof showPrintButton !== 'undefined' && showPrintButton) { %>
  <div class="student-result-actions no-print">
    <% if (printAction === 'print') { %>
      <button type="button" class="btn btn--gold" onclick="window.print()">Print Result</button>
    <% } else { %>
      <a
        href="/results/print?term=<%= encodeURIComponent(term) %>&session=<%= encodeURIComponent(session) %>"
        class="btn btn--gold"
        target="_blank"
        rel="noopener"
      >Print Result</a>
    <% } %>
  </div>
<% } %>
