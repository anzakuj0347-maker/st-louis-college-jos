<header class="print-ca-header">
  <div class="print-ca-header-left">
    <img src="/images/logo.jpg" alt="St. Louis College Jos Logo" class="print-school-logo">
    <div>
      <h1 class="print-school-name">St. Louis College Jos</h1>
      <p class="print-doc-title">Student Terminal Report</p>
    </div>
  </div>
  <div class="print-ca-header-right">
    <table class="print-meta-table">
      <tr><th>Student ID</th><td><%= student.studentId %></td></tr>
      <tr><th>Name</th><td><%= student.firstName %><% if (student.middleName) { %> <%= student.middleName %><% } %> <%= student.lastName %></td></tr>
      <tr><th>Class</th><td><%= classLevel %> Arm <%= student.arm || '—' %></td></tr>
      <tr><th>Term</th><td><%= term %></td></tr>
      <tr><th>Session</th><td><%= session %></td></tr>
    </table>
  </div>
</header>

<table class="print-data-table print-result-table">
  <thead>
    <tr>
      <th>S/N</th>
      <th>Subject</th>
      <th>1st Asgn</th>
      <th>2nd Asgn</th>
      <th>1st Test</th>
      <th>2nd Test</th>
      <th>Exam</th>
      <th>Total</th>
      <th>Average</th>
      <th>Position</th>
      <th>Grade</th>
      <th>Remark</th>
      <th>Sign</th>
    </tr>
  </thead>
  <tbody>
    <% if (subjectResults.length) { %>
      <% subjectResults.forEach(function(row, index) { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= row.subject %></td>
          <td><%= row.firstAssignment !== '' ? row.firstAssignment : '—' %></td>
          <td><%= row.secondAssignment !== '' ? row.secondAssignment : '—' %></td>
          <td><%= row.firstTest !== '' ? row.firstTest : '—' %></td>
          <td><%= row.secondTest !== '' ? row.secondTest : '—' %></td>
          <td><%= row.exam !== '' ? row.exam : '—' %></td>
          <td><%= row.total || '—' %></td>
          <td><%= row.average !== '' && row.average !== undefined ? row.average : '—' %></td>
          <td><%= row.position || '—' %></td>
          <td><%= row.grade || '—' %></td>
          <td><%= row.remark || '—' %></td>
          <td><%= row.sign || '—' %></td>
        </tr>
      <% }); %>
    <% } else { %>
      <tr>
        <td colspan="13" class="print-empty">No results recorded for this term and session.</td>
      </tr>
    <% } %>
  </tbody>
</table>

<section class="print-result-summary">
  <h2>Result Summary</h2>
  <div class="print-summary-grid">
    <div class="print-summary-item">
      <span class="print-summary-label">Subjects Offered</span>
      <strong><%= summary.subjectsOffered %></strong>
    </div>
    <div class="print-summary-item">
      <span class="print-summary-label">Number of Credits</span>
      <strong><%= summary.numberOfCredits %></strong>
    </div>
    <div class="print-summary-item">
      <span class="print-summary-label">Class Average</span>
      <strong><%= summary.classAverage || '—' %></strong>
    </div>
  </div>
  <div class="print-principal-comment">
    <h3>Principal's Comment</h3>
    <p><%= summary.principalComment %></p>
  </div>
</section>

<footer class="print-ca-footer">
  <div class="print-signature-block">
    <p class="print-signature-line">Class Teacher's Signature</p>
  </div>
  <div class="print-signature-block">
    <p class="print-signature-line">Principal's Signature</p>
  </div>
</footer>

<% if (typeof showPrintButton !== 'undefined' && showPrintButton) { %>
  <div class="student-result-actions no-print">
    <% if (printAction === 'print') { %>
      <button type="button" class="btn btn--gold" onclick="window.print()">Print Result</button>
    <% } else { %>
      <a
        href="/results/print?term=<%= encodeURIComponent(term) %>&session=<%= encodeURIComponent(session) %>"
        class="btn btn--gold"
        target="_blank"
        rel="noopener"
      >Print Result</a>
    <% } %>
  </div>
<% } %>
