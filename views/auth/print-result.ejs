<%- include('../partials/doc-start', { title: title, bodyClass: 'print-result-page' }) %>

<div class="print-toolbar no-print">
  <p>
    Student Terminal Report — <strong><%= student.firstName %> <%= student.lastName %></strong>
    (<%= student.studentId %>) | <%= classLevel %> Arm <%= student.arm || '—' %>
    | <%= term %> | <%= session %>
  </p>
  <div class="print-toolbar-actions">
    <a href="/results/dashboard?term=<%= encodeURIComponent(term) %>&session=<%= encodeURIComponent(session) %>" class="btn btn--outline">Back to Dashboard</a>
    <button type="button" class="btn btn--gold" id="printResultBtn">Print Result</button>
  </div>
</div>

<div class="print-result-stage">
<div class="print-result-fit">
<section class="print-only print-ca-sheet student-terminal-report student-terminal-report--print">
  <%- include('partials/student-result-sheet', {
    student,
    classLevel,
    term,
    session,
    subjectResults,
    summary,
    qrImageUrl: qr ? qr.qrImageUrl : '',
    verifyUrl: qr ? qr.verifyUrl : '',
    showPrintButton: false
  }) %>
</section>
</div>
</div>

<script src="/js/print-result.js"></script>
<%- include('../partials/doc-end') %>
