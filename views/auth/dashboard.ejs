<%- include('../partials/doc-start', { title: 'My Results' }) %>
<%- include('../partials/header') %>

<section class="page-hero page-hero--compact">
  <div class="container">
    <p class="eyebrow">Check Result</p>
    <h1>Welcome, <%= user.firstName %> <%= user.lastName %></h1>
    <p>Class: <%= user.classLevel %> | Student ID: <%= user.studentId %></p>
  </div>
</section>

<section class="page-content">
  <div class="container">
    <div class="dashboard-actions">
      <form method="POST" action="/results/logout">
        <button type="submit" class="btn btn--outline">Logout</button>
      </form>
    </div>

    <form class="admin-form student-result-filters" method="GET" action="/results/dashboard">
      <div class="admin-form-grid">
        <div class="form-group">
          <label for="period">Session *</label>
          <select id="period" name="period" required>
            <option value=""<%= !selectedPeriod ? ' selected' : '' %>>Select session</option>
            <% sessionOptions.forEach(function(opt) {
              const value = opt.session + '||' + opt.term;
            %>
              <option value="<%= value %>"<%= selectedPeriod === value ? ' selected' : '' %>>
                <%= opt.label %><%= opt.isActive ? ' (Active)' : '' %>
              </option>
            <% }); %>
          </select>
        </div>
      </div>
      <button type="submit" class="btn btn--outline btn--sm">View Results</button>
    </form>

    <% if (!sessionOptions.length) { %>
      <p>No sessions available yet. Please check back later.</p>
    <% } else if (!hasSelection) { %>
      <p class="admin-form-note">Select a session, then click <strong>View Results</strong> to see your scores.</p>
    <% } else if (resultView && resultView.subjectResults.length) { %>
      <section class="print-only print-ca-sheet student-terminal-report student-terminal-report--embedded no-print-chrome">
        <%- include('partials/student-result-sheet', {
          student: resultView.student,
          classLevel: resultView.classLevel,
          term: resultView.term,
          session: resultView.session,
          subjectResults: resultView.subjectResults,
          summary: resultView.summary,
          qrImageUrl: resultView.qr ? resultView.qr.qrImageUrl : '',
          verifyUrl: resultView.qr ? resultView.qr.verifyUrl : '',
          showPrintButton: canPrint,
          printAction: 'link'
        }) %>
      </section>
    <% } else { %>
      <p>No results found for <%= term %>, <%= session %> yet.</p>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/doc-end') %>
