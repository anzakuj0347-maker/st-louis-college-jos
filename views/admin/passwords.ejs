<%- include('../partials/doc-start', { title: title }) %>
<%- include('../partials/header') %>

<section class="page-hero page-hero--compact password-screen-only">
  <div class="container">
    <p class="eyebrow">Administration</p>
    <h1><%= pageTitle %></h1>
  </div>
</section>

<section class="page-content">
  <div class="container admin-layout password-screen-only">
    <%- include('../partials/admin-sidebar', { activeSection: activeSection }) %>
    <div class="admin-main">
      <% if (success) { %><div class="alert alert--success"><%= success %></div><% } %>
      <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>

      <div class="admin-panel">
        <h2 class="admin-panel-title">Login Credentials (<%= credentials.length %>)</h2>
        <p class="admin-form-note">Student passwords are for Check Result login. Staff passwords are for the score entry portal.</p>

        <form class="password-print-filters admin-form" method="GET" action="/slc-admin/passwords/print" target="_blank">
          <div class="admin-form-grid">
            <div class="form-group">
              <label for="printType">Print cards for *</label>
              <select id="printType" name="type" required>
                <option value="">Select type</option>
                <option value="student">Students</option>
                <option value="staff">Staff</option>
              </select>
            </div>
            <div class="form-group" id="printClassLevelGroup" hidden>
              <label for="printClassLevel">Class level</label>
              <select id="printClassLevel" name="classLevel">
                <option value="">All classes</option>
                <% classLevels.forEach(function(level) { %>
                  <option value="<%= level %>"><%= level %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group" id="printArmGroup" hidden>
              <label for="printArm">Arm</label>
              <select id="printArm" name="arm">
                <option value="">All arms</option>
                <% arms.forEach(function(armOption) { %>
                  <option value="<%= armOption %>"><%= armOption %></option>
                <% }); %>
              </select>
            </div>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="btn btn--gold">Print Cards</button>
          </div>
          <p class="admin-form-note">Opens a print view with 10 cards per page. For students, you can filter by class level and arm.</p>
        </form>
      </div>

      <div class="admin-panel">
        <%- include('../partials/admin-search', { searchPlaceholder: searchPlaceholder }) %>
        <% if (credentials.length) { %>
          <div class="admin-table-wrap">
            <table class="data-table admin-table" data-admin-search-table>
              <thead>
                <tr>
                  <th>Type</th>
                  <th>Login ID</th>
                  <th>Name</th>
                  <th>Details</th>
                  <th>Password</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% credentials.forEach(function(c) { %>
                  <tr data-search-row="<%= c.type %> <%= c.loginId %> <%= c.name %> <%= c.detail %> <%= c.classLevel %> <%= c.arm %>">
                    <td><%= c.type === 'student' ? 'Student' : 'Staff' %></td>
                    <td><%= c.loginId %></td>
                    <td><%= c.name %></td>
                    <td><%= c.detail || '—' %></td>
                    <td><code><%= c.password || 'Not set' %></code></td>
                    <td class="admin-actions">
                      <form method="POST" action="/slc-admin/passwords/<%= c.type === 'student' ? 'students' : 'staff' %>/<%= c.id %>/regenerate" class="admin-inline-form" onsubmit="return confirm('Generate a new password for <%= c.loginId %>?');">
                        <button type="submit" class="admin-action-link">Regenerate</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <p class="admin-search-empty" data-admin-search-empty hidden>No credentials match your search.</p>
        <% } else { %>
          <p class="admin-empty">No students or staff yet.</p>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/doc-end') %>
<script src="/js/admin-search.js"></script>
<script>
(function () {
  const printType = document.getElementById('printType');
  const classGroup = document.getElementById('printClassLevelGroup');
  const armGroup = document.getElementById('printArmGroup');

  function syncPrintFilters() {
    const isStudent = printType.value === 'student';
    classGroup.hidden = !isStudent;
    armGroup.hidden = !isStudent;
    if (!isStudent) {
      document.getElementById('printClassLevel').value = '';
      document.getElementById('printArm').value = '';
    }
  }

  printType.addEventListener('change', syncPrintFilters);
  syncPrintFilters();
})();
</script>
