<%- include('../partials/doc-start', { title: title }) %>
<%- include('../partials/header') %>

<section class="page-hero page-hero--compact">
  <div class="container">
    <p class="eyebrow">Administration</p>
    <h1><%= pageTitle %></h1>
    <p>Filter students by class and arm, then set fee status. Paid students can view results; owing students can log in but results are blocked.</p>
  </div>
</section>

<section class="page-content">
  <div class="container admin-layout">
    <%- include('../partials/admin-sidebar', { activeSection: activeSection }) %>
    <div class="admin-main">
      <% if (success) { %><div class="alert alert--success"><%= success %></div><% } %>
      <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>

      <div class="admin-panel">
        <h2 class="admin-panel-title">Filter Students</h2>
        <form class="admin-form" method="GET" action="/slc-admin/fees">
          <div class="admin-form-grid">
            <div class="form-group">
              <label for="classLevel">Class Level *</label>
              <select id="classLevel" name="classLevel" required>
                <option value="">Select class</option>
                <% classLevels.forEach(function(level) { %>
                  <option value="<%= level %>"<%= classLevel === level ? ' selected' : '' %>><%= level %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label for="arm">Arm *</label>
              <select id="arm" name="arm" required>
                <option value="">Select arm</option>
                <% arms.forEach(function(armOption) { %>
                  <option value="<%= armOption %>"<%= arm === armOption ? ' selected' : '' %>><%= armOption %></option>
                <% }); %>
              </select>
            </div>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="btn btn--outline">Load Students</button>
          </div>
        </form>
      </div>

      <% if (classLevel && arm) { %>
        <div class="admin-panel">
          <h2 class="admin-panel-title">
            <%= classLevel %> Arm <%= arm %>
            (<%= students.length %>)
          </h2>

          <% if (students.length) { %>
            <form class="admin-form" method="POST" action="/slc-admin/fees" id="feesForm">
              <input type="hidden" name="classLevel" value="<%= classLevel %>">
              <input type="hidden" name="arm" value="<%= arm %>">

              <p class="admin-form-note">
                <strong>Paid</strong> — login allowed, result accessible.
                <strong>Owing</strong> — login allowed, result blocked.
              </p>

              <div class="admin-form-actions fees-bulk-actions">
                <button type="button" class="btn btn--outline btn--sm" id="feesMarkPaid">Mark All Paid</button>
                <button type="button" class="btn btn--outline btn--sm" id="feesMarkOwing">Mark All Owing</button>
              </div>

              <%- include('../partials/admin-search', { searchPlaceholder: searchPlaceholder }) %>

              <div class="admin-table-wrap">
                <table class="data-table admin-table" data-admin-search-table>
                  <thead>
                    <tr>
                      <th>Student ID</th>
                      <th>Name</th>
                      <th>Class</th>
                      <th>Arm</th>
                      <th>Fee Status</th>
                      <th>Login</th>
                      <th>Result</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% students.forEach(function(s) { %>
                      <tr data-search-row="<%= s.studentId %> <%= s.firstName %> <%= s.middleName || '' %> <%= s.lastName %> <%= s.classLevel %> <%= s.arm || '' %> <%= s.access.feeStatus %> paid owing allowed accessible blocked">
                        <td><%= s.studentId %></td>
                        <td><%= s.firstName %><% if (s.middleName) { %> <%= s.middleName %><% } %> <%= s.lastName %></td>
                        <td><%= s.classLevel %></td>
                        <td><%= s.arm || '—' %></td>
                        <td>
                          <select name="feeStatus[<%= s._id %>]" class="fee-status-select" data-student-id="<%= s._id %>">
                            <option value="paid"<%= s.access.feeStatus === 'paid' ? ' selected' : '' %>>Paid</option>
                            <option value="owing"<%= s.access.feeStatus === 'owing' ? ' selected' : '' %>>Owing</option>
                          </select>
                        </td>
                        <td>
                          <span class="fee-access-badge fee-access-badge--allowed">Allowed</span>
                        </td>
                        <td>
                          <span class="fee-access-badge fee-access-badge--result<%= s.access.resultAccessible ? ' fee-access-badge--allowed' : ' fee-access-badge--blocked' %>" data-result-badge="<%= s._id %>">
                            <%= s.access.resultAccessible ? 'Accessible' : 'Blocked' %>
                          </span>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>

              <p class="admin-search-empty" data-admin-search-empty hidden>No students match your search.</p>

              <div class="admin-form-actions">
                <button type="submit" class="btn btn--gold">Save Fee Status</button>
              </div>
            </form>
          <% } else { %>
            <p class="admin-empty">No students found in <%= classLevel %> Arm <%= arm %>.</p>
          <% } %>
        </div>
      <% } else { %>
        <div class="admin-panel">
          <p class="admin-form-note">Choose a class level and arm, then click <strong>Load Students</strong>.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<script>
  (function () {
    const form = document.getElementById('feesForm');
    if (!form) return;

    const selects = form.querySelectorAll('.fee-status-select');
    const markPaid = document.getElementById('feesMarkPaid');
    const markOwing = document.getElementById('feesMarkOwing');

    function updateResultBadge(select) {
      const studentId = select.getAttribute('data-student-id');
      const badge = form.querySelector('[data-result-badge="' + studentId + '"]');
      if (!badge) return;

      const isPaid = select.value === 'paid';
      badge.textContent = isPaid ? 'Accessible' : 'Blocked';
      badge.classList.toggle('fee-access-badge--allowed', isPaid);
      badge.classList.toggle('fee-access-badge--blocked', !isPaid);
    }

    selects.forEach(function (select) {
      select.addEventListener('change', function () {
        updateResultBadge(select);
      });
    });

    if (markPaid) {
      markPaid.addEventListener('click', function () {
        selects.forEach(function (select) {
          select.value = 'paid';
          updateResultBadge(select);
        });
      });
    }

    if (markOwing) {
      markOwing.addEventListener('click', function () {
        selects.forEach(function (select) {
          select.value = 'owing';
          updateResultBadge(select);
        });
      });
    }
  })();
</script>
<script src="/js/admin-search.js"></script>

<%- include('../partials/footer') %>
<%- include('../partials/doc-end') %>
