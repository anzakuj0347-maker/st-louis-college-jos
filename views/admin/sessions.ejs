<%- include('../partials/doc-start', { title: title }) %>
<%- include('../partials/header') %>

<section class="page-hero page-hero--compact">
  <div class="container">
    <p class="eyebrow">Administration</p>
    <h1><%= pageTitle %></h1>
    <p>Create academic sessions and set which session is active for staff score entry.</p>
  </div>
</section>

<section class="page-content">
  <div class="container admin-layout">
    <%- include('../partials/admin-sidebar', { activeSection: activeSection }) %>
    <div class="admin-main">
      <% if (success) { %><div class="alert alert--success"><%= success %></div><% } %>
      <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>

      <div class="admin-panel">
        <h2 class="admin-panel-title">Add Session</h2>
        <form class="admin-form" method="POST" action="/slc-admin/sessions">
          <div class="admin-form-grid">
            <div class="form-group">
              <label for="name">Session Name *</label>
              <input type="text" id="name" name="name" required placeholder="e.g. 2025/2026">
            </div>
            <div class="form-group">
              <label for="isActive">Status</label>
              <select id="isActive" name="isActive">
                <option value="false">Inactive</option>
                <option value="true">Active</option>
              </select>
            </div>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="btn btn--gold">Create Session</button>
          </div>
        </form>
      </div>

      <div class="admin-panel">
        <h2 class="admin-panel-title">All Sessions (<%= sessions.length %>)</h2>
        <% if (sessions.length) { %>
          <div class="admin-table-wrap">
            <table class="data-table admin-table">
              <thead>
                <tr>
                  <th>Session</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% sessions.forEach(function(s) { %>
                  <tr>
                    <td><%= s.name %></td>
                    <td>
                      <% if (s.isActive) { %>
                        <span class="session-badge session-badge--active">Active</span>
                      <% } else { %>
                        <span class="session-badge session-badge--inactive">Inactive</span>
                      <% } %>
                    </td>
                    <td class="admin-actions">
                      <form method="POST" action="/slc-admin/sessions/<%= s._id %>/toggle" class="admin-inline-form">
                        <button type="submit" class="admin-action-link">
                          <%= s.isActive ? 'Deactivate' : 'Activate' %>
                        </button>
                      </form>
                      <form method="POST" action="/slc-admin/sessions/<%= s._id %>/delete" class="admin-inline-form" onsubmit="return confirm('Delete this session?');">
                        <button type="submit" class="admin-action-link admin-action-link--danger">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="admin-empty">No sessions yet. Create one above to enable staff score entry.</p>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/doc-end') %>
