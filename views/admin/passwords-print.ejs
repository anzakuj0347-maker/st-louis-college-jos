<%- include('../partials/doc-start', { title: title }) %>

<div class="password-print-toolbar no-print">
  <p>
    Printing <strong><%= printType === 'student' ? 'Student' : 'Staff' %></strong> cards
    (<%= credentials.length %>)
    <% if (printType === 'student' && classLevel) { %> — Class: <strong><%= classLevel %></strong><% } %>
    <% if (printType === 'student' && arm) { %> — Arm: <strong><%= arm %></strong><% } %>
  </p>
  <button type="button" class="btn btn--gold" onclick="window.print()">Print</button>
  <button type="button" class="btn btn--outline" onclick="window.close()">Close</button>
</div>

<section class="password-print-only password-print-view">
  <% for (let page = 0; page < credentials.length; page += 10) { %>
    <div class="password-print-page">
      <% credentials.slice(page, page + 10).forEach(function(c) { %>
        <article class="password-card">
          <p class="password-card-school">St. Louis College Jos</p>
          <p class="password-card-type"><%= c.type === 'student' ? 'Student Login' : 'Staff Login' %></p>
          <p class="password-card-name"><%= c.name %></p>
          <p class="password-card-row"><span>ID</span><strong><%= c.loginId %></strong></p>
          <p class="password-card-row"><span>Password</span><strong><%= c.password || '—' %></strong></p>
          <% if (c.detail) { %>
            <p class="password-card-detail"><%= c.detail %></p>
          <% } %>
        </article>
      <% }); %>
    </div>
  <% } %>
</section>

<%- include('../partials/doc-end') %>
