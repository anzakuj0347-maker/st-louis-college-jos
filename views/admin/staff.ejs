<%- include('../partials/doc-start', { title: title }) %>
<%- include('../partials/header') %>

<section class="page-hero page-hero--compact">
  <div class="container">
    <p class="eyebrow">Administration</p>
    <h1><%= pageTitle %></h1>
  </div>
</section>

<section class="page-content">
  <div class="container admin-layout">
    <%- include('../partials/admin-sidebar', { activeSection: activeSection }) %>
    <div class="admin-main">
      <% if (success) { %><div class="alert alert--success"><%= success %></div><% } %>
      <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>

      <div class="admin-panel">
        <h2 class="admin-panel-title"><%= editStaff ? 'Edit Staff' : 'Add Staff' %></h2>
        <form class="admin-form" method="POST" action="<%= editStaff ? '/slc-admin/staff/' + editStaff._id : '/slc-admin/staff' %>">
          <div class="admin-form-grid">
            <div class="form-group">
              <label for="staffId">Staff ID *</label>
              <input type="text" id="staffId" name="staffId" required value="<%= editStaff ? editStaff.staffId : '' %>">
            </div>
            <div class="form-group">
              <label for="firstName">First Name *</label>
              <input type="text" id="firstName" name="firstName" required value="<%= editStaff ? editStaff.firstName : '' %>">
            </div>
            <div class="form-group">
              <label for="lastName">Last Name *</label>
              <input type="text" id="lastName" name="lastName" required value="<%= editStaff ? editStaff.lastName : '' %>">
            </div>
            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="text" id="phone" name="phone" value="<%= editStaff ? editStaff.phone || '' : '' %>">
            </div>
            <% if (editStaff) { %>
              <div class="form-group admin-form-full">
                <label class="admin-checkbox-label">
                  <input type="checkbox" name="regeneratePassword" value="on">
                  Generate new staff login password
                </label>
              </div>
            <% } %>
          </div>
          <% if (!editStaff) { %>
            <p class="admin-form-note">A login password will be generated automatically and shown after the staff member is created.</p>
          <% } %>
          <div class="admin-form-actions">
            <button type="submit" class="btn btn--gold"><%= editStaff ? 'Update Staff' : 'Add Staff' %></button>
            <% if (editStaff) { %><a href="/slc-admin/staff" class="btn btn--outline">Cancel</a><% } %>
          </div>
        </form>
      </div>

      <div class="admin-panel">
        <h2 class="admin-panel-title">All Staff (<%= staffList.length %>)</h2>
        <%- include('../partials/admin-search', { searchPlaceholder: searchPlaceholder }) %>
        <% if (staffList.length) { %>
          <div class="admin-table-wrap">
            <table class="data-table admin-table" data-admin-search-table>
              <thead>
                <tr>
                  <th>Staff ID</th>
                  <th>Name</th>
                  <th>Assignments</th>
                  <th>Phone</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% staffList.forEach(function(s) { %>
                  <tr data-search-row="<%= s.staffId %> <%= s.firstName %> <%= s.lastName %> <%= s.phone || '' %>">
                    <td><%= s.staffId %></td>
                    <td><%= s.firstName %> <%= s.lastName %></td>
                    <td><%= s.classAssignments ? s.classAssignments.length : 0 %> class(es)</td>
                    <td><%= s.phone || '—' %></td>
                    <td class="admin-actions">
                      <a href="/slc-admin/staff/<%= s._id %>/assign" class="admin-action-link">Assign</a>
                      <a href="/slc-admin/staff/<%= s._id %>/edit" class="admin-action-link">Edit</a>
                      <form method="POST" action="/slc-admin/staff/<%= s._id %>/delete" class="admin-inline-form" onsubmit="return confirm('Delete this staff member?');">
                        <button type="submit" class="admin-action-link admin-action-link--danger">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <p class="admin-search-empty" data-admin-search-empty hidden>No staff match your search.</p>
        <% } else { %>
          <p class="admin-empty">No staff yet. Add one above.</p>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/doc-end') %>
<script src="/js/admin-search.js"></script>
