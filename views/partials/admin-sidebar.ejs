<button type="button" class="admin-sidebar-fab" id="adminSidebarToggle" aria-expanded="false" aria-controls="adminSidebar" aria-label="Open admin menu">
  <span aria-hidden="true">☰</span>
</button>
<div class="admin-sidebar-backdrop" id="adminSidebarBackdrop" hidden aria-hidden="true"></div>
<aside class="admin-sidebar" id="adminSidebar" aria-hidden="false">
  <div class="admin-sidebar-top">
    <p class="admin-sidebar-label">SLC Admin</p>
    <button type="button" class="admin-sidebar-close" id="adminSidebarClose" aria-label="Close admin menu">&times;</button>
  </div>
  <div class="admin-sidebar-body" id="adminSidebarBody">
    <% if (typeof adminNav !== 'undefined') { %>
      <nav aria-label="Admin navigation">
        <ul class="admin-sidebar-nav">
          <% adminNav.forEach(function(item) { %>
            <li>
              <a href="<%= item.path %>" class="admin-sidebar-link<%= activeSection === item.key ? ' active' : '' %>">
                <%= item.label %>
              </a>
            </li>
          <% }); %>
        </ul>
      </nav>
    <% } %>
    <% if (typeof adminNav !== 'undefined') { %>
      <form method="POST" action="/slc-admin/logout" class="admin-logout-form">
        <button type="submit" class="btn btn--outline btn--sm">Logout</button>
      </form>
    <% } %>
  </div>
</aside>
