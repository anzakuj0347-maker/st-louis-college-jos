<%- include('../partials/doc-start', { title: page.title }) %>
<%- include('../partials/header') %>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow"><%= page.section.replace('-', ' ').replace(/\b\w/g, c => c.toUpperCase()) %></p>
    <h1><%= page.title %></h1>
  </div>
</section>

<section class="page-content">
  <div class="container content-body">
    <%- page.content %>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/doc-end') %>
