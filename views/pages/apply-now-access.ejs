<%- include('../partials/doc-start', { title: 'Apply Now - Access' }) %>
<%- include('../partials/header') %>

<section class="page-hero page-hero--compact">
  <div class="container">
    <p class="eyebrow">Admission</p>
    <h1>Application Access</h1>
    <p>Enter the 6-digit PIN provided by the school to open the admission form or reprint a submitted application.</p>
  </div>
</section>

<section class="page-content">
  <div class="container auth-container">
    <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>

    <form class="auth-form apply-access-form" method="POST" action="/admission/apply-now/access">
      <div class="form-group">
        <label for="pin">Admission PIN *</label>
        <input
          type="text"
          id="pin"
          name="pin"
          required
          inputmode="numeric"
          pattern="\d{6}"
          maxlength="6"
          minlength="6"
          autocomplete="one-time-code"
          placeholder="Enter 6-digit PIN"
          value="<%= pin || '' %>"
        >
      </div>
      <button type="submit" class="btn btn--gold">Continue</button>
    </form>

    <p class="auth-hint">
      New applicants use a PIN once to submit. If your PIN was already used, you can enter it again to preview and print your submitted form.
    </p>
    <p class="auth-hint">
      <a href="/admission/applications/review">Preview application with reference number</a>
    </p>
    <p class="auth-hint">
      Email: <a href="mailto:<%= schoolEmail %>"><%= schoolEmail %></a>
    </p>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/doc-end') %>
