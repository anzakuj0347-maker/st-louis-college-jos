<%- include('../partials/doc-start', { title: 'Contact Us' }) %>
<%- include('../partials/header') %>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">Get in Touch</p>
    <h1>Contact Us</h1>
  </div>
</section>

<section class="page-content">
  <div class="container contact-grid">
    <div class="contact-info">
      <h2>St. Louis College Jos</h2>
      <p><strong>Address:</strong> Jos, Plateau State, Nigeria</p>
      <p><strong>Email:</strong> <a href="mailto:info@stlouisvillejos.sch.ng">info@stlouisvillejos.sch.ng</a></p>
      <p><strong>School Hours:</strong> Monday – Friday, 7:30 AM – 3:30 PM</p>
      <p><strong>Admission:</strong> <a href="/admission/apply-now">Apply Now</a></p>
    </div>
    <form class="contact-form" method="POST" action="/contact">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert--error"><%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert--success"><%= success %></div>
      <% } %>
      <div class="form-group">
        <label for="name">Your Name *</label>
        <input type="text" id="name" name="name" required value="<%= typeof form !== 'undefined' && form ? form.name : '' %>">
      </div>
      <div class="form-group">
        <label for="email">Your Email *</label>
        <input type="email" id="email" name="email" required value="<%= typeof form !== 'undefined' && form ? form.email : '' %>">
      </div>
      <div class="form-group">
        <label for="subject">Subject</label>
        <input type="text" id="subject" name="subject" value="<%= typeof form !== 'undefined' && form ? form.subject : '' %>">
      </div>
      <div class="form-group">
        <label for="message">Message *</label>
        <textarea id="message" name="message" rows="6" required><%= typeof form !== 'undefined' && form ? form.message : '' %></textarea>
      </div>
      <button type="submit" class="btn btn--gold">Send Message</button>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/doc-end') %>
