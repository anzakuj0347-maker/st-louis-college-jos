PORT=3000
# Local database — used on your PC while working offline
LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017/stlouis_college_jos
# Atlas — set as MONGODB_URI on Render; used locally for sync destination
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/stlouis_college_jos
REMOTE_MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/stlouis_college_jos
REMOTE_MONGODB_URI_STANDARD=
SESSION_SECRET=change-this-to-a-random-secret-string
